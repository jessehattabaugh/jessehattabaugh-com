{
	"AWSTemplateFormatVersion": "2010-09-09",
	"Description": "HTTP API Gateway for the application, integrating with a Lambda function.",
	"Parameters": {
		"ProjectName": {
			"Type": "String",
			"Description": "A name for the project, used to prefix resource names."
		},
		"BranchName": {
			"Type": "String",
			"Description": "The current Git branch name, used for naming and tagging."
		},
		"LambdaFunctionArn": {
			"Type": "String",
			"Description": "ARN of the Lambda function to integrate with."
		},
		"ApiGatewayStageName": {
			"Type": "String",
			"Description": "Name for the API Gateway stage.",
			"Default": "$default"
		}
	},
	"Resources": {
		"HttpApi": {
			"Type": "AWS::ApiGatewayV2::Api",
			"Properties": {
				"Name": {
					"Fn::Sub": "${ProjectName}-HttpApi-${BranchName}-${AWS::Region}"
				},
				"ProtocolType": "HTTP",
				"CorsConfiguration": {
					"AllowOrigins": ["*"],
					"AllowMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD"],
					"AllowHeaders": ["*"],
					"MaxAge": 300
				},
				"Target": { "Ref": "LambdaFunctionArn" }
			}
		},
		"LambdaPermission": {
			"Type": "AWS::Lambda::Permission",
			"Properties": {
				"Action": "lambda:InvokeFunction",
				"FunctionName": { "Ref": "LambdaFunctionArn" },
				"Principal": "apigateway.amazonaws.com",
				"SourceArn": {
					"Fn::Sub": "arn:aws:apigateway:${AWS::Region}::/apis/${HttpApi}/*/*"
				}
			}
		},
		"ApiStage": {
			"Type": "AWS::ApiGatewayV2::Stage",
			"Properties": {
				"ApiId": { "Ref": "HttpApi" },
				"StageName": { "Ref": "ApiGatewayStageName" },
				"AutoDeploy": true,
				"Tags": {
					"Project": { "Ref": "ProjectName" },
					"Branch": { "Ref": "BranchName" }
				}
			}
		}
	},
	"Outputs": {
		"ApiId": {
			"Description": "ID of the HTTP API Gateway",
			"Value": { "Ref": "HttpApi" }
		},
		"ApiEndpoint": {
			"Description": "Endpoint URL for the HTTP API Gateway Stage",
			"Value": {
				"Fn::Sub": "https://${HttpApi}.execute-api.${AWS::Region}.amazonaws.com/${ApiStage}"
			}
		}
	}
}
