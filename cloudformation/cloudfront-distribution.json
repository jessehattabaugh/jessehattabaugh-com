{
	"AWSTemplateFormatVersion": "2010-09-09",
	"Description": "CloudFront distribution for serving static assets from S3 and dynamic content from API Gateway.",
	"Parameters": {
		"ProjectName": {
			"Type": "String",
			"Description": "A name for the project, used for naming and tagging."
		},
		"BranchName": {
			"Type": "String",
			"Description": "The current Git branch name, for tagging and naming."
		},
		"StaticAssetsS3BucketDomainName": {
			"Type": "String",
			"Description": "Domain name of the S3 bucket for static assets (e.g., mybucket.s3.amazonaws.com)."
		},
		"CloudFrontOAIId": {
			"Type": "String",
			"Description": "ID of the CloudFront Origin Access Identity for S3."
		},
		"ApiGatewayId": {
			"Type": "String",
			"Description": "ID of the API Gateway (used to construct the origin domain)."
		},
		"ApiGatewayStageName": {
			"Type": "String",
			"Description": "Stage name of the API Gateway (e.g., '$default' or 'prod'). Used for the OriginPath."
		},
		"AcmCertificateArn": {
			"Type": "String",
			"Description": "ARN of the ACM certificate for HTTPS (must be in us-east-1)."
		},
		"CloudFrontAliases": {
			"Type": "CommaDelimitedList",
			"Description": "Comma-delimited list of CNAMEs (domain names) for the distribution."
		},
		"StaticAssetPathPattern": {
			"Type": "String",
			"Description": "Path pattern for static assets to be served from S3 (e.g., 'static/*').",
			"Default": "static/*"
		}
	},
	"Resources": {
		"WebAppDistribution": {
			"Type": "AWS::CloudFront::Distribution",
			"Properties": {
				"DistributionConfig": {
					"Comment": {
						"Fn::Sub": "${ProjectName} Web App Distribution for ${BranchName}"
					},
					"Enabled": true,
					"HttpVersion": "http2",
					"PriceClass": "PriceClass_100",
					"Aliases": { "Ref": "CloudFrontAliases" },
					"ViewerCertificate": {
						"AcmCertificateArn": { "Ref": "AcmCertificateArn" },
						"SslSupportMethod": "sni-only",
						"MinimumProtocolVersion": "TLSv1.2_2021"
					},
					"Origins": [
						{
							"Id": "S3Origin",
							"DomainName": { "Ref": "StaticAssetsS3BucketDomainName" },
							"OriginPath": { "Fn::Sub": "/${BranchName}" },
							"S3OriginConfig": {
								"OriginAccessIdentity": {
									"Fn::Sub": "origin-access-identity/cloudfront/${CloudFrontOAIId}"
								}
							}
						},
						{
							"Id": "ApiGatewayOrigin",
							"DomainName": {
								"Fn::Sub": "${ApiGatewayId}.execute-api.${AWS::Region}.amazonaws.com"
							},
							"OriginPath": {
								"Fn::If": [
									"IsDefaultStage",
									"",
									{ "Fn::Sub": "/${ApiGatewayStageName}" }
								]
							},
							"CustomOriginConfig": {
								"HTTPSPort": 443,
								"OriginProtocolPolicy": "https-only",
								"OriginSSLProtocols": ["TLSv1.2"]
							}
						}
					],
					"DefaultCacheBehavior": {
						"TargetOriginId": "ApiGatewayOrigin",
						"ViewerProtocolPolicy": "redirect-to-https",
						"AllowedMethods": [
							"GET",
							"HEAD",
							"OPTIONS",
							"PUT",
							"POST",
							"PATCH",
							"DELETE"
						],
						"CachedMethods": ["GET", "HEAD", "OPTIONS"],
						"Compress": true,
						"ForwardedValues": {
							"QueryString": true,
							"Cookies": { "Forward": "all" },
							"Headers": ["Authorization", "Host"]
						},
						"MinTTL": 0,
						"DefaultTTL": 0,
						"MaxTTL": 31536000
					},
					"CacheBehaviors": [
						{
							"PathPattern": { "Ref": "StaticAssetPathPattern" },
							"TargetOriginId": "S3Origin",
							"ViewerProtocolPolicy": "redirect-to-https",
							"AllowedMethods": ["GET", "HEAD", "OPTIONS"],
							"CachedMethods": ["GET", "HEAD", "OPTIONS"],
							"Compress": true,
							"MinTTL": 0,
							"DefaultTTL": 86400,
							"MaxTTL": 31536000
						}
					]
				},
				"Tags": [
					{ "Key": "Project", "Value": { "Ref": "ProjectName" } },
					{ "Key": "Branch", "Value": { "Ref": "BranchName" } }
				]
			}
		}
	},
	"Conditions": {
		"IsDefaultStage": { "Fn::Equals": [{ "Ref": "ApiGatewayStageName" }, "$default"] }
	},
	"Outputs": {
		"DistributionId": {
			"Description": "CloudFront Distribution ID",
			"Value": { "Ref": "WebAppDistribution" }
		},
		"DistributionDomainName": {
			"Description": "CloudFront Distribution Domain Name",
			"Value": { "Fn::GetAtt": ["WebAppDistribution", "DomainName"] }
		}
	}
}
