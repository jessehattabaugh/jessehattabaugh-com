{
	"AWSTemplateFormatVersion": "2010-09-09",
	"Description": "Root CloudFormation stack for jessehattabaugh.com. Manages S3, IAM, CloudFront, API Gateway, Lambda, Route 53, and CodeBuild resources.",
	"Parameters": {
		"ProjectName": {
			"Type": "String",
			"Description": "A name for the project, used to prefix resource names for uniqueness and clarity.",
			"Default": "jessehattabaugh-com"
		},
		"DomainName": {
			"Type": "String",
			"Description": "The root domain name (e.g., example.com) for the website."
		},
		"Subdomain": {
			"Type": "String",
			"Description": "The subdomain for the current environment (e.g., 'www', 'dev', or branch name). Use '@' for the root domain.",
			"Default": "@"
		},
		"HostedZoneId": {
			"Type": "AWS::Route53::HostedZone::Id",
			"Description": "The Route 53 Hosted Zone ID for the DomainName."
		},
		"AcmCertificateArn": {
			"Type": "String",
			"Description": "ARN of the ACM SSL/TLS certificate for the domain/subdomain. Must be in us-east-1 for CloudFront."
		},
		"BranchName": {
			"Type": "String",
			"Description": "The current Git branch name, used for tagging and conditional resource naming.",
			"Default": "main"
		},
		"StaticAssetsS3BucketName": {
			"Type": "String",
			"Description": "Name for the S3 bucket that will store static assets. Will be prefixed with project name and suffixed with region."
		},
		"LambdaFunctionNames": {
			"Type": "String",
			"Description": "Comma-separated list of Lambda function names derived from the 'pages' directory (e.g., 'hello,about'). Provided by CodeBuild."
		},
		"LambdaHandler": {
			"Type": "String",
			"Description": "Default handler for the Lambda functions (e.g., 'index.handler').",
			"Default": "index.handler"
		},
		"LambdaRuntime": {
			"Type": "String",
			"Description": "Default runtime for the Lambda functions (e.g., 'nodejs20.x').",
			"Default": "nodejs20.x"
		},
		"ApiGatewayStageName": {
			"Type": "String",
			"Description": "Name for the API Gateway stage.",
			"Default": "$default"
		},
		"StaticAssetPathPattern": {
			"Type": "String",
			"Description": "Path pattern for static assets in CloudFront (e.g., static/*).",
			"Default": "static/*"
		},
		"GitHubRepoUrl": {
			"Type": "String",
			"Description": "URL of the GitHub source code repository (e.g., https://github.com/user/repo.git)."
		},
		"CodeBuildRootStackNamePrefix": {
			"Type": "String",
			"Description": "Prefix for the CloudFormation root stack name deployed by CodeBuild (branch name will be appended by buildspec).",
			"Default": "WebAppStack"
		},
		"LambdaCodeS3KeyPatternForBuild": {
			"Type": "String",
			"Description": "S3 key pattern for Lambda code used by CodeBuild (e.g., lambda/{branch}/app.zip). The {branch} placeholder will be replaced by the buildspec.",
			"Default": "lambda/{branch}/app.zip"
		},
		"GitHubRepoName": {
			"Type": "String",
			"Description": "The name of the GitHub repository (e.g., 'owner/repo').",
			"Default": "jessehattabaugh/jessehattabaugh-com"
		}
	},
	"Mappings": {
		"RegionMap": {
			"us-east-1": { "RegionAlias": "ue1" },
			"us-west-2": { "RegionAlias": "uw2" }
		}
	},
	"Conditions": {
		"IsRootDomain": { "Fn::Equals": [{ "Ref": "Subdomain" }, "@"] }
	},
	"Resources": {
		"CloudFrontOAI": {
			"Type": "AWS::CloudFront::CloudFrontOriginAccessIdentity",
			"Properties": {
				"CloudFrontOriginAccessIdentityConfig": {
					"Comment": { "Fn::Sub": "OAI for ${ProjectName} static assets" }
				}
			}
		},
		"S3StaticAssetsBucketStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./s3-static-assets-bucket.json",
				"Parameters": {
					"CloudFrontOAICanonicalUserId": {
						"Fn::GetAtt": "CloudFrontOAI.S3CanonicalUserId"
					},
					"BucketName": {
						"Fn::Sub": "${ProjectName}-static-assets-${AWS::Region}"
					}
				}
			}
		},
		"IAMRolesStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./iam-roles.json",
				"Parameters": {
					"ArtifactsBucketArn": {
						"Fn::GetAtt": "StaticAssetsBucketStack.Outputs.BucketArn"
					},
					"ProjectName": { "Ref": "ProjectName" }
				}
			}
		},
		"ApiGatewayStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./api-gateway.json",
				"Parameters": {
					"ProjectName": { "Ref": "ProjectName" },
					"BranchName": { "Ref": "BranchName" },
					"ApiGatewayStageName": { "Ref": "ApiGatewayStageName" },
					"LambdaFunctionNames": { "Ref": "LambdaFunctionNames" },
					"RootLambdaFunctionArn": ""
				}
			}
		},
		"CloudFrontDistributionStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./cloudfront-distribution.json",
				"Parameters": {
					"ProjectName": { "Ref": "ProjectName" },
					"BranchName": { "Ref": "BranchName" },
					"StaticAssetsS3BucketDomainName": {
						"Fn::GetAtt": "StaticAssetsBucketStack.Outputs.BucketDomainName"
					},
					"CloudFrontOAIId": {
						"Fn::GetAtt": "CloudFrontOAI.CloudFrontOriginAccessIdentityId"
					},
					"ApiGatewayId": { "Fn::GetAtt": ["ApiGatewayStack", "Outputs.ApiGatewayId"] },
					"ApiGatewayStageName": { "Ref": "ApiGatewayStageName" },
					"AcmCertificateArn": { "Ref": "AcmCertificateArn" },
					"CloudFrontAliases": {
						"Fn::If": [
							"IsRootDomain",
							{ "Ref": "DomainName" },
							{ "Fn::Sub": "${Subdomain}.${DomainName}" }
						]
					},
					"StaticAssetPathPattern": { "Ref": "StaticAssetPathPattern" }
				}
			},
			"DependsOn": ["ApiGatewayStack", "StaticAssetsBucketStack", "CloudFrontOAI"]
		},
		"Route53RecordsStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./route53-records.json",
				"Parameters": {
					"HostedZoneId": { "Ref": "HostedZoneId" },
					"FullDomainName": {
						"Fn::If": [
							"IsRootDomain",
							{ "Ref": "DomainName" },
							{ "Fn::Sub": "${Subdomain}.${DomainName}" }
						]
					},
					"CloudFrontDistributionDomainName": {
						"Fn::GetAtt": "CloudFrontDistributionStack.Outputs.DistributionDomainName"
					}
				}
			},
			"DependsOn": "CloudFrontDistributionStack"
		},
		"CodeBuildProjectStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./codebuild-project.json",
				"Parameters": {
					"ProjectName": { "Ref": "ProjectName" },
					"CodeBuildServiceRoleArn": {
						"Fn::GetAtt": "IamRolesStack.Outputs.CodeBuildServiceRoleArn"
					},
					"SourceRepositoryUrl": { "Ref": "GitHubRepoUrl" },
					"RootStackNamePrefix": { "Ref": "CodeBuildRootStackNamePrefix" },
					"EnvVarProjectNameForCfn": { "Ref": "ProjectName" },
					"EnvVarDomainNameForCfn": { "Ref": "DomainName" },
					"EnvVarSubdomainBaseForCfn": { "Ref": "Subdomain" },
					"EnvVarHostedZoneIdForCfn": { "Ref": "HostedZoneId" },
					"EnvVarAcmCertificateArnForCfn": { "Ref": "AcmCertificateArn" },
					"EnvVarStaticAssetsS3BucketNameForCfn": { "Ref": "StaticAssetsS3BucketName" },
					"EnvVarLambdaFunctionNameForCfn": { "Ref": "LambdaFunctionName" },
					"EnvVarLambdaHandlerForCfn": { "Ref": "LambdaHandler" },
					"EnvVarLambdaRuntimeForCfn": { "Ref": "LambdaRuntime" },
					"EnvVarLambdaCodeS3KeyPatternForCfn": {
						"Ref": "LambdaCodeS3KeyPatternForBuild"
					},
					"EnvVarApiGatewayStageNameForCfn": { "Ref": "ApiGatewayStageName" },
					"EnvVarStaticAssetPathPatternForCfn": { "Ref": "StaticAssetPathPattern" }
				}
			},
			"DependsOn": ["IamRolesStack"]
		},
		"EventBridgeRuleStack": {
			"Type": "AWS::CloudFormation::Stack",
			"Properties": {
				"TemplateURL": "./eventbridge-rule.json",
				"Parameters": {
					"ProjectName": {
						"Ref": "ProjectName"
					},
					"BranchName": {
						"Ref": "BranchName"
					},
					"CodeBuildProjectArn": {
						"Fn::GetAtt": ["CodeBuildProjectStack", "Outputs.CodeBuildProjectArn"]
					},
					"GitHubRepoName": {
						"Ref": "GitHubRepoName"
					}
				}
			}
		}
	},
	"Outputs": {
		"StaticAssetsS3BucketNameOutput": {
			"Description": "Name of the S3 bucket for static assets",
			"Value": { "Fn::GetAtt": "StaticAssetsBucketStack.Outputs.BucketName" }
		},
		"StaticAssetsS3BucketDomainNameOutput": {
			"Description": "Domain name of the S3 bucket for static assets",
			"Value": { "Fn::GetAtt": "StaticAssetsBucketStack.Outputs.BucketDomainName" }
		},
		"CodeBuildServiceRoleArnOutput": {
			"Description": "ARN of the CodeBuild service role",
			"Value": { "Fn::GetAtt": "IamRolesStack.Outputs.CodeBuildServiceRoleArn" }
		},
		"LambdaExecutionRoleArnOutput": {
			"Description": "ARN of the Lambda execution role",
			"Value": { "Fn::GetAtt": "IamRolesStack.Outputs.LambdaExecutionRoleArn" }
		},
		"ApiGatewayEndpointOutput": {
			"Description": "Endpoint URL for the HTTP API Gateway Stage",
			"Value": { "Fn::GetAtt": "ApiGatewayStack.Outputs.ApiEndpoint" }
		},
		"CloudFrontDistributionIdOutput": {
			"Description": "ID of the CloudFront distribution",
			"Value": { "Fn::GetAtt": "CloudFrontDistributionStack.Outputs.DistributionId" }
		},
		"CloudFrontDistributionDomainNameOutput": {
			"Description": "Domain name of the CloudFront distribution",
			"Value": { "Fn::GetAtt": "CloudFrontDistributionStack.Outputs.DistributionDomainName" }
		},
		"CodeBuildProjectArnOutput": {
			"Description": "ARN of the AWS CodeBuild project created.",
			"Value": { "Fn::GetAtt": "CodeBuildProjectStack.Outputs.CodeBuildProjectArn" }
		},
		"EventBridgeRuleArn": {
			"Description": "ARN of the EventBridge Rule",
			"Value": {
				"Fn::GetAtt": ["EventBridgeRuleStack", "Outputs.EventBridgeRuleArn"]
			}
		}
	}
}
