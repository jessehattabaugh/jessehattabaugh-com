{
	"name": "jessehattabaugh-com",
	"version": "1.0.0",
	"description": "Personal website of Jesse Hattabaugh",
	"dependencies": {
		"aws-cdk-lib": "^2.100.0",
		"constructs": "^10.3.0",
		"marko": "^5.33.0"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@types/node": "^20.5.0",
		"aws-cdk": "^2.100.0",
		"eslint": "latest",
		"eslint-config-prettier": "latest",
		"eslint-plugin-compat": "latest",
		"eslint-plugin-promise": "latest",
		"eslint-plugin-sonarjs": "latest",
		"eslint-plugin-unicorn": "latest",
		"playwright": "^1.40.0",
		"typescript": "^5.2.0"
	},
	"scripts": {
		"build": "cdk synth",
		"build:staging": "cdk synth --context environment=staging",
		"build:prod": "cdk synth --context environment=production",
		"deploy": "cdk deploy --context environment=production",
		"deploy:staging": "cdk deploy --context environment=staging",
		"destroy": "cdk destroy",
		"destroy:staging": "cdk destroy --context environment=staging",
		"destroy:prod": "cdk destroy --context environment=production",
		"diff": "cdk diff --context environment=staging",
		"diff:prod": "cdk diff --context environment=production",
		"lint": "eslint",
		"lint:fix": "npm run lint -- --fix",
		"test": "TEST_URL=https://staging.jessehattabaugh.com playwright test",
		"test:prod": "TEST_URL=https://jessehattabaugh.com playwright test"
	},
	"type": "module"
}
