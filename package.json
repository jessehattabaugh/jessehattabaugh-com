{
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@playwright/test": "latest",
		"@types/node": "latest",
		"eslint-config-prettier": "latest",
		"eslint-plugin-compat": "latest",
		"eslint-plugin-promise": "latest",
		"eslint-plugin-sonarjs": "latest",
		"eslint-plugin-unicorn": "latest",
		"netlify-cli": "latest",
		"playwright": "latest"
	},
	"scripts": {
		"deploy": "node scripts/deploy.js --prod",
		"deploy:staging": "node scripts/deploy.js --alias staging",
		"dev": "netlify dev",
		"lint": "eslint",
		"lint:fix": "npm run lint -- --fix",
		"test": "npm run test:e2e:staging",
		"test:e2e:staging": "playwright test",
		"test:e2e": "TEST_URL=https://jessehattabaugh.com playwright test"
	},
	"type": "module"
}