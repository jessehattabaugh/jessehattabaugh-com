{
	"devDependencies": {
		"@aws-sdk/client-sts": "latest",
		"@aws-sdk/credential-provider-ini": "latest",
		"@aws-sdk/credential-providers": "^3.855.0",
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@playwright/test": "latest",
		"@types/node": "latest",
		"aws-cdk": "latest",
		"constructs": "latest",
		"dotenv": "latest",
		"esbuild": "latest",
		"eslint-config-prettier": "latest",
		"eslint-plugin-compat": "latest",
		"eslint-plugin-promise": "latest",
		"eslint-plugin-sonarjs": "latest",
		"eslint-plugin-unicorn": "latest",
		"playwright": "latest"
	},
	"dependencies": {
		"aws-cdk-lib": "latest",
		"constructs": "latest"
	},
	"scripts": {
		"build": "cdk synth --context environment=production",
		"build:staging": "cdk synth --context environment=staging",
		"deploy": "cdk deploy JesseHattabaughProdStack",
		"deploy:staging:dev": "npm run deploy:staging -- --context developmentMode=true --require-approval never",
		"deploy:staging:fast": "npm run deploy:staging -- --context skipCloudFront=true --require-approval never",
		"deploy:staging:hotswap": "npm run deploy:staging -- --hotswap --require-approval never",
		"deploy:staging": "npm run build:staging && cdk deploy JesseHattabaughStagingStack",
		"destroy": "cdk destroy JesseHattabaughProdStack",
		"destroy:staging": "cdk destroy JesseHattabaughStagingStack",
		"diff": "cdk diff JesseHattabaughProdStack",
		"diff:staging": "cdk diff JesseHattabaughStagingStack",
		"lint": "eslint",
		"lint:fix": "npm run lint -- --fix",
		"test": "npm run test:unit && npm run test:e2e:staging",
		"test:e2e:staging": "TEST_URL=https://staging.jessehattabaugh.com playwright test",
		"test:e2e": "TEST_URL=https://jessehattabaugh.com playwright test",
		"test:unit:watch": "node --test --watch tests/unit/**/*.test.js",
		"test:unit": "node --test tests/unit/**/*.test.js"
	},
	"type": "module"
}
