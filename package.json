{
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@playwright/test": "latest",
		"@types/node": "latest",
		"eslint-config-prettier": "latest",
		"eslint-plugin-compat": "latest",
		"eslint-plugin-promise": "latest",
		"eslint-plugin-sonarjs": "latest",
		"eslint-plugin-unicorn": "latest",
		"playwright": "latest",
		"wrangler": "latest"
	},
	"scripts": {
		"deploy": "node scripts/deploy.js",
		"deploy:staging": "node scripts/deploy.js --branch staging",
		"dev": "wrangler pages dev .",
		"lint": "eslint",
		"lint:fix": "npm run lint -- --fix",
		"test": "npm run test:unit && npm run test:e2e:staging",
		"test:e2e:staging": "TEST_URL=https://jessehattabaugh-com.pages.dev playwright test",
		"test:e2e": "TEST_URL=https://jessehattabaugh.com playwright test",
		"test:unit:watch": "node --test --watch tests/unit/**/*.test.js",
		"test:unit": "node --test tests/unit/**/*.test.js"
	},
	"type": "module"
}